# ============================================================
#  ПРОВАЙДЕР ПЕРЕКЛАДУ — вибери один блок (A або B)
# ============================================================

# ----- A: DeepSeek (найдешевше; потрібен баланс на акаунті) -----
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# ----- B: справжній Anthropic Claude (твій ключ; base URL не потрібен) -----
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# MODEL=claude-haiku-4-5

# ============================================================
#  АВТОРИЗАЦІЯ
# ============================================================
# ОБОВ'ЯЗКОВО зміни на довгий випадковий рядок (інакше токени можна підробити).
# Згенерувати: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# Адмін-користувачі (через кому). Хто в списку — той адмін і авто-схвалений.
# Реєструйся цим email, щоб отримати доступ до /admin.
ADMIN_EMAILS=admin@example.com

# ============================================================
#  ТАРИФІКАЦІЯ
# ============================================================
RATE_UAH=30          # ціна за сторінку
PAGE_CHARS=1800      # знаків (із пробілами) у сторінці
BILL_ON=source       # рахувати за 'source' (оригінал) чи 'target' (переклад)

# ============================================================
#  ПЕРЕКЛАД / APP
# ============================================================
PORT=3000
SOURCE_LANG=російської
TARGET_LANG=українською
CHUNK_CHARS=3000

# ============================================================
#  ТОКЕНАЙЗЕР + ОЦІНКА ВАРТОСТІ API (опційно)
# ============================================================
# У Docker-compose ставиться автоматично (http://tokenizer:8000).
# Локально без Docker — лиши порожнім, тоді показ токенів просто вимкнеться.
TOKENIZER_URL=
# Ціни DeepSeek для орієнтовної оцінки ($/1M токенів)
DEEPSEEK_PRICE_IN=0.14
DEEPSEEK_PRICE_OUT=0.28
